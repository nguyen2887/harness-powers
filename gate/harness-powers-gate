#!/usr/bin/env bash
# harness-powers hard gate (PreToolUse hook for Claude Code, Codex, and Grok).
#
# Blocks edits to code until the plan-review gate has been recorded for active
# normal/high-risk mailbox tasks and in-progress stories. Dormant roadmap stories
# whose status is merely `planned` do not block unrelated work.
#
# Fail-open by design: any uncertainty (no harness.db, no CLI, unparseable input,
# a whitelisted/non-code path) ALLOWS the edit. It only ever denies when it is
# certain there is an active, unreviewed normal/high-risk task.
#
# Contract: reads the hook JSON payload on stdin; exit 0 = allow, exit 2 = deny
# (all three CLIs treat exit code 2 as a block and surface stderr to the model).

payload="$(cat 2>/dev/null || true)"

# Extract string values for any of the pipe-separated key names.
json_strs() {
  printf '%s' "$payload" \
    | grep -oE "\"($1)\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" \
    | sed -E 's/.*:[[:space:]]*"([^"]*)".*/\1/'
}

tool="$(json_strs 'tool_name|toolName' | head -1)"
files="$(json_strs 'file_path|filePath|path')"
root="$(json_strs 'workspaceRoot|workspace_root|cwd|projectDir' | head -1)"

# Codex apply_patch carries target paths inside one JSON-escaped patch string,
# not in file_path. Decode escaped newlines only far enough to read every patch
# header. Multiple targets matter: a docs-first patch must not hide a code edit.
patch_files="$(printf '%s' "$payload" \
  | sed 's/\\n/\
/g' \
  | sed -nE 's/^\*\*\* (Add|Update|Delete) File: (.*)$/\2/p')"
if [ -n "$patch_files" ]; then
  if [ -n "$files" ]; then files="$(printf '%s\n%s' "$files" "$patch_files")"
  else files="$patch_files"
  fi
fi

# Only guard edit-like tools. Anything else is allowed outright.
case "$tool" in
  Edit|Write|MultiEdit|apply_patch|str_replace*|create_file|edit_file|"") : ;;
  *) exit 0 ;;
esac

# Without a file target there is nothing to reason about.
[ -n "$files" ] || exit 0

# Locate the harness repo (the directory holding harness.db).
first_file="$(printf '%s\n' "$files" | head -1)"
case "$first_file" in /*) ;; *) first_file="${root:-$PWD}/$first_file" ;; esac
start="$root"; [ -n "$start" ] || start="$(dirname "$first_file")"
repo=""; d="$start"
while [ -n "$d" ] && [ "$d" != "/" ] && [ "$d" != "." ]; do
  if [ -f "$d/harness.db" ]; then repo="$d"; break; fi
  d="$(dirname "$d")"
done
[ -n "$repo" ] || exit 0   # not a harness repo -> never interfere

# Whitelist: docs, harness bookkeeping, and agent config are always allowed
# (designing writes story docs before the review; config is not product code).
# Continue to gate evaluation when ANY target is product code.
guarded_target=no
while IFS= read -r file; do
  [ -n "$file" ] || continue
  case "$file" in /dev/null) continue ;; esac
  case "$file" in /*) ;; *) file="${root:-$repo}/$file" ;; esac
  case "$file" in "$repo"/*) rel="${file#"$repo"/}" ;; *) continue ;; esac
  case "$rel" in
    docs/*|.harness-powers/*|harness.db*|.codex/*|.agents/*|.claude/*|.grok/*|*.md) ;;
    *) guarded_target=yes ;;
  esac
done <<< "$files"
[ "$guarded_target" = yes ] || exit 0

# Need the CLI to inspect state; if it is missing we cannot check -> allow.
cli="$repo/scripts/bin/harness-cli"
[ -x "$cli" ] || cli="$repo/scripts/bin/harness-cli.exe"
[ -x "$cli" ] || exit 0

blockers=""

add_blocker() {
  local id="$1"
  [ -n "$id" ] || return
  case ",$blockers," in *",$id,"*) return ;; esac
  if [ -n "$blockers" ]; then blockers="$blockers,$id"; else blockers="$id"; fi
}

has_plan_approval() {
  local story="$1" raw count
  case "$story" in ""|*[!A-Za-z0-9._-]*) return 2 ;; esac
  raw="$(cd "$repo" && "$cli" query sql "SELECT count(*) FROM intervention WHERE story_id='$story' AND type='approval' AND source='reviewer' AND description LIKE 'plan-review passed:%';" 2>/dev/null)" || return 2
  count="$(printf '%s\n' "$raw" | awk '/^[[:space:]]*[0-9]+[[:space:]]*$/ {gsub(/[[:space:]]/, ""); value=$0} END {print value}')"
  [ -n "$count" ] || return 2
  [ "$count" -gt 0 ]
}

# Mailbox tasks represent work that is actually active. Planned roadmap stories
# with no open mailbox task are intentionally ignored.
runtime="$repo/.harness-powers/runtime/tasks"
if [ -d "$runtime" ]; then
  for task_dir in "$runtime"/*; do
    [ -d "$task_dir/fields" ] || continue
    task="$(basename "$task_dir")"
    lane="$(sed -n '1p' "$task_dir/fields/lane" 2>/dev/null || true)"
    stage="$(sed -n '1p' "$task_dir/fields/stage" 2>/dev/null || true)"
    case "$lane:$stage" in normal:closed|high-risk:closed) continue ;; esac
    case "$lane" in normal|high-risk) ;; *) continue ;; esac
    story="$(sed -n '1p' "$task_dir/fields/story_id" 2>/dev/null || true)"
    if [ -z "$story" ]; then
      add_blocker "$task"
      continue
    fi
    has_plan_approval "$story"; approval_status=$?
    case "$approval_status" in
      0) ;;
      1) add_blocker "$story" ;;
      *) exit 0 ;; # uncertain database result -> fail open
    esac
  done
fi

# Fallback for an implementation whose runtime mailbox was lost: in-progress
# stories remain guarded. Merely planned roadmap stories are not selected.
sql_in_progress="SELECT group_concat(s.id, ',') FROM story s WHERE s.risk_lane IN ('normal','high_risk') AND s.status='in_progress' AND NOT EXISTS (SELECT 1 FROM intervention i WHERE i.story_id=s.id AND i.type='approval' AND i.source='reviewer' AND i.description LIKE 'plan-review passed:%');"
raw_in_progress="$(cd "$repo" && "$cli" query sql "$sql_in_progress" 2>/dev/null)" || exit 0
db_blockers="$(printf '%s\n' "$raw_in_progress" | grep -viE 'group_concat|^-+$' | tr -d ' \t' | grep -vE '^$' | head -1)"
if [ -n "$db_blockers" ]; then
  old_ifs="$IFS"; IFS=','
  for story in $db_blockers; do add_blocker "$story"; done
  IFS="$old_ifs"
fi

# No active, unreviewed normal/high-risk task -> allow.
[ -n "$blockers" ] || exit 0

# Deny: a plan-review gate is outstanding.
{
  echo "[harness-powers gate] BLOCKED: plan-review gate not passed for active task/story: ${blockers}."
  echo "Edits outside docs/ are blocked until the plan is reviewed."
  echo "Continue the durable task with: work <task-id>"
  echo "After plan review and freeze, the human unlocks it with: approve <task-id>"
  echo "Self-review is allowed only when explicitly accepted and recorded as degraded independence."
} >&2
exit 2
